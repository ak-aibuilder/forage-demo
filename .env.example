# Required at runtime on Railway and for local agent calls.
OPENAI_API_KEY=replace_with_your_openai_api_key

# Optional runtime overrides. The defaults are suitable for this repository.
OPENAI_BASE_URL=https://api.openai.com/v1
FORAGE_AGENT_MODEL=gpt-5.6-sol
FORAGE_DEFAULT_BUDGET=150

# Optional repository-relative data paths.
FORAGE_ENRICHED_INDEX_PATH=data/enriched-index.json
FORAGE_INVENTORY_PATH=data/inventory-config.json
FORAGE_CATALOG_PATH=data/apparel.csv

# Used only by the batch enrichment command.
FORAGE_ENRICHMENT_MODEL=gpt-5.6-terra
